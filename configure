#!/bin/bash
#
# Configure apostol-crm-crm — wraps cmake with sensible defaults.
# Downloads modules/processes from GitHub (like v1 configure).
# libapostol is a git submodule; everything else is cloned/pulled.
#
# Usage: ./configure [OPTIONS]

set -e

PROJECT_NAME=apostol-crm
BUILD_TYPE=Release
PULL_GITHUB=yes

# CMake feature flags (matching CMakeLists.txt cache variables)
WITH_POSTGRESQL=ON
WITH_SSL=ON
WITH_CURL=ON
APP_NAME=apostol-crm

# --- Helpers --------------------------------------------------------------

pop_directory()  { popd  >/dev/null; }
push_directory() { pushd "$1" >/dev/null; }

display_heading_message() { echo; echo "********************** $* **********************"; echo; }
display_message()         { echo "$@"; }
display_error()           { >&2 echo "$@"; }

download_from_github()
{
    local DIRECTORY=$1
    local ACCOUNT=$2
    local REPO=$3
    local BRANCH=$4
    local DIR=$5

    push_directory "$DIRECTORY"

    local FORK="$ACCOUNT/$REPO"

    if ! [ -d "$DIR" ]; then
        display_heading_message "Download: $FORK/$BRANCH"
        git clone --depth 1 --branch "$BRANCH" --single-branch "https://github.com/$FORK" "$DIR"
    else
        push_directory "$DIR"
        display_heading_message "Updating: $FORK/$BRANCH"
        git pull
        pop_directory
    fi

    pop_directory
}

display_help()
{
    display_message "Usage: ./configure [OPTION]..."
    display_message ""
    display_message "Build options:"
    display_message "  --release                Release build (default)"
    display_message "  --debug                  Debug build"
    display_message "  --update                 Reconfigure without deleting the build directory"
    display_message "  --build-dir=<path>       Location of build files (default: cmake-build-{type})"
    display_message ""
    display_message "Feature flags:"
    display_message "  --with-postgresql        Enable PostgreSQL / libpq support (default: on)"
    display_message "  --without-postgresql     Disable PostgreSQL support"
    display_message "  --without-ssl            Disable OpenSSL support (default: on)"
    display_message "  --without-curl           Disable libcurl support (default: on)"
    display_message "  --app-name=<name>        Application binary / config name (default: apostol-crm)"
    display_message ""
    display_message "  --not-pull-github        Skip downloading/updating from GitHub"
    display_message "  --help                   Display this help"
    display_message ""
}

display_configuration()
{
    display_message "Configuration"
    display_message "--------------------------------------------------------------------"
    display_message "PROJECT_NAME         : $PROJECT_NAME"
    display_message "BUILD_TYPE           : $BUILD_TYPE"
    display_message "BUILD_DIR            : $BUILD_DIR"
    display_message "WITH_POSTGRESQL      : $WITH_POSTGRESQL"
    display_message "WITH_SSL             : $WITH_SSL"
    display_message "WITH_CURL            : $WITH_CURL"
    display_message "APP_NAME             : $APP_NAME"
    display_message "--------------------------------------------------------------------"
}

make_configuration()
{
    if ! [[ $BUILD_UPDATE ]]; then
        rm -rf "$BUILD_DIR"
        mkdir -p "$BUILD_DIR"
    fi

    display_heading_message "Configuring: $PROJECT_NAME"

    cmake \
        -DCMAKE_BUILD_TYPE="$BUILD_TYPE" \
        -DWITH_POSTGRESQL="$WITH_POSTGRESQL" \
        -DWITH_SSL="$WITH_SSL" \
        -DWITH_CURL="$WITH_CURL" \
        -DAPP_NAME="$APP_NAME" \
        -B "$BUILD_DIR" .

    display_message ""
    echo -e "********************** \e[32;1mSUCCESS\e[0m **********************"
    echo -e "\e[32m-- To build $PROJECT_NAME run:\e[0m"
    display_message "--------------------------------------------------------------------"
    echo -e "\e[1m\$ cmake --build $BUILD_DIR --parallel \$(nproc)\e[0m"
    display_message "--------------------------------------------------------------------"
    echo -e "\e[32m-- To install $PROJECT_NAME run:\e[0m"
    display_message "--------------------------------------------------------------------"
    echo -e "\e[1m\$ sudo cmake --install $BUILD_DIR\e[0m"
    display_message "--------------------------------------------------------------------"
}

# --- Parse options --------------------------------------------------------

for OPTION in "$@"; do
    case $OPTION in
        (--help)               DISPLAY_HELP=yes ;;

        (--release)            BUILD_TYPE=Release ;;
        (--debug)              BUILD_TYPE=Debug ;;
        (--update)             BUILD_UPDATE=yes ;;

        (--with-postgresql)    WITH_POSTGRESQL=ON ;;
        (--without-postgresql) WITH_POSTGRESQL=OFF ;;
        (--without-ssl)        WITH_SSL=OFF ;;
        (--without-curl)       WITH_CURL=OFF ;;

        (--not-pull-github)    PULL_GITHUB=no ;;
        (--app-name=*)         APP_NAME="${OPTION#*=}" ;;
        (--build-dir=*)        BUILD_DIR="${OPTION#*=}" ;;
    esac
done

if ! [[ $BUILD_DIR ]]; then
    if [[ $BUILD_TYPE == Debug ]]; then
        BUILD_DIR=cmake-build-debug
    else
        BUILD_DIR=cmake-build-release
    fi
fi

# --- Run ------------------------------------------------------------------

if [[ $DISPLAY_HELP ]]; then
    display_help
else
    # libapostol — git submodule
    if [[ -d .git ]]; then
        display_heading_message "Updating submodules"
        git submodule update --init --remote
    fi

    # Modules, processes, db-platform — clone/pull from GitHub
    if [[ $PULL_GITHUB == yes ]]; then
        download_from_github src/modules/Workers  apostoldevel module-AppServer      master AppServer
        download_from_github src/modules/Workers  apostoldevel module-AuthServer     master AuthServer
        download_from_github src/modules/Workers  apostoldevel module-FileServer     master FileServer
        download_from_github src/modules/Workers  apostoldevel module-PGHTTP         master PGHTTP
        download_from_github src/modules/Workers  apostoldevel module-WebServer      master WebServer
        download_from_github src/modules/Workers  apostoldevel module-WebSocketAPI   master WebSocketAPI

        download_from_github src/modules/Helpers  apostoldevel module-PGFetch        master PGFetch
        download_from_github src/modules/Helpers  apostoldevel module-PGFile         master PGFile

        download_from_github src/processes        apostoldevel process-MessageServer master MessageServer
        download_from_github src/processes        apostoldevel process-ReportServer  master ReportServer
        download_from_github src/processes        apostoldevel process-TaskScheduler master TaskScheduler

        download_from_github db/sql               apostoldevel db-platform           master platform
    fi

    display_configuration
    make_configuration
fi
